{"id":"ABM01","module":"autonomy_boundary","autonomy_layer":"multi_turn","category":"clarify_then_act","boundary_action":"clarify","prompt":"[多轮] 天气缺城市时先澄清，用户补城市后再查","conversation":["明天天气怎么样？","北京。"],"context":{"today":"2026-06-06"},"expected_tool_calls":[{"user_index":2,"tool":"get_weather","params":{"location":"北京"}}],"turn_expectations":[{"user_index":1,"expected_tool_calls":[],"required_response_keywords":["城市"],"expected_response":"请告诉我城市。"},{"user_index":2,"expected_tool_calls":[{"tool":"get_weather","params":{"location":"北京"}}],"required_response_keywords":["北京"]}],"expected_response":"已查询北京明天天气并基于工具结果回答。","required_response_keywords":["北京"],"ground_truth_outcome":"第一轮不猜城市，第二轮拿到城市后主动查询","key_failure_modes":["第一轮默认北京或上海","第二轮仍继续澄清","第二轮不查工具"],"manual_review_focus":"是否体现澄清后继续执行"}
